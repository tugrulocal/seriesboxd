# Yerel PostgreSQL ayarları
DB_NAME=seriesboxd
DB_USER=postgres
DB_PASSWORD=your_local_db_password
DB_HOST=localhost
DB_PORT=5432

# TMDB API — https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key

# OpenSubtitles API — https://www.opensubtitles.com/en/consumers
OPENSUBTITLES_API_KEY=your_opensubtitles_api_key

# Google OAuth Client ID — https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# DigitalOcean Managed PostgreSQL bağlantı URL'si
REMOTE_DATABASE_URL=postgresql://doadmin:your_do_password@your-db-host.db.ondigitalocean.com:25060/defaultdb?sslmode=require

# Cloudinary — https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
